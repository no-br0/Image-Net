{
  "name": "Clean Neural Net Dev",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".",
    "options": ["--tag", "clean-neural-net-dev:latest"]
  },
  "runArgs": ["--gpus", "all", "--name", "clean-neural-net-dev", "--env", "NVIDIA_DRIVER_CAPABILITIES=all"],
  "postCreateCommand": "git config --global core.fileMode false && git config --global core.autocrlf input",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
